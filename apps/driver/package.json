{
  "name": "@delivery/driver",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "vue-tsc -b && vite build",
    "build:staging": "vue-tsc -b && vite build --mode staging",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:staging": "pnpm build:staging && wrangler deploy --env staging"
  },
  "dependencies": {
    "@delivery/shared": "workspace:*",
    "firebase": "^12.15.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6",
    "wrangler": "^4.107.0"
  }
}
