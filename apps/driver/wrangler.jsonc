{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "delivery-driver",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "env": {
    "staging": {
      "workers_dev": true,
      "preview_urls": false
    }
  }
}
