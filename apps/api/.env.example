DATABASE_URL=postgres://postgres:postgres@localhost:5432/delivery
APP_ENV=local

# Primeiro ADMIN. Defina ADMIN_PASSWORD no ambiente somente durante db:seed.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# Email de ativacao (Resend)
RESEND_API_KEY=
AUTH_CODE_SECRET=replace-with-at-least-32-random-bytes
EMAIL_FROM=Delivo <onboarding@resend.dev>
PUBLIC_WEB_URL=http://localhost:5173
# Opcional em local/staging; proibido em producao.
EMAIL_ALLOWED_RECIPIENTS=
