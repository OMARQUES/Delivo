{
  "name": "@delivery/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset:demo": "tsx src/db/demo-reset-cli.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:demo": "tsx src/db/demo-seed.ts",
    "cf-typegen": "wrangler types worker-configuration.d.ts --env staging --env-interface CloudflareBindings --strict-vars=false --include-runtime=false"
  },
  "dependencies": {
    "@delivery/shared": "workspace:*",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@types/node": "^22.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
